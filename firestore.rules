rules_version = '2';
service cloud.firestore {
match /databases/{database}/documents {

function isSignedIn() {
return request.auth != null;
}

function isOwner() {
return isSignedIn() &&
get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner';
}

match /users/{userId} {
allow read: if isSignedIn();
allow create: if isSignedIn() && request.auth.uid == userId
&& request.resource.data.role == 'collaborator';
allow update: if isSignedIn() && (request.auth.uid == userId || isOwner());
allow delete: if isOwner();
}

match /activities/{id} {
allow read: if isSignedIn();
allow create, delete: if isOwner();
allow update: if isOwner() ||
(isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['notes', 'attachments']));
}

match /occurrences/{id} {
allow read, write: if isSignedIn();
}

match /timeLogs/{id} {
allow read, write: if isSignedIn();
}

match /clients/{id} {
allow read, write: if isSignedIn();
}

match /leads/{id} {
allow read: if isSignedIn();
allow write: if isOwner();
}

match /links/{id} {
allow read: if isSignedIn();
allow write: if isOwner();
}

match /dailyReports/{id} {
allow read, write: if isOwner();
}

match /cards/{id} {
allow read, write: if isSignedIn();
}

match /payables/{id} {
allow read, write: if isOwner();
}

match /payableOccurrences/{id} {
allow read, write: if isOwner();
}

match /payablesArchive/{id} {
allow read, write: if isOwner();
}

match /boletosClientes/{id} {
allow read: if isSignedIn();
allow write: if isOwner();
}

match /chatMessages/{id} {
allow read: if isSignedIn();
allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
allow update, delete: if isOwner() || (isSignedIn() && resource.data.uid == request.auth.uid);
}
}
}
